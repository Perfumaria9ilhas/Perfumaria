generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomerAccount {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String   @unique
  passwordHash String?
  phone      String
  address    String
  orders     SiteOrder[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  origin    String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  description      String
  imageUrl         String
  priceInCents     Int
  salePriceInCents Int?
  stock            Int
  audience         ProductAudience   @default(UNISSEXO)
  concentration    ProductConcentration @default(EDP)
  availableInFiveMl Boolean          @default(true)
  availableInTenMl  Boolean          @default(false)
  active           Boolean           @default(true)
  featured         Boolean           @default(false)
  bestseller       Boolean           @default(false)
  brandId          String
  categoryId       String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  brand            Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category         Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  wishes           OutOfStockWish[]
  orderItems       SiteOrderItem[]

  @@index([brandId])
  @@index([categoryId])
}

enum ProductAudience {
  FEMININO
  MASCULINO
  UNISSEXO
}

enum ProductConcentration {
  EDT
  EDP
  PARFUM
  EXTRAIT
  ELIXIR
}

model SiteOrder {
  id                String           @id @default(cuid())
  reference         String           @unique
  source            String           @default("site")
  status            String           @default("novo")
  customerAccountId String?
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  customerAddress   String?
  totalInCents      Int
  whatsappMessage   String
  items             SiteOrderItem[]
  customerAccount   CustomerAccount? @relation(fields: [customerAccountId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([createdAt])
  @@index([status])
}

model SiteOrderItem {
  id            String    @id @default(cuid())
  orderId       String
  productId     String?
  productName   String
  brandName     String
  unitPriceInCents Int
  quantity      Int
  lineTotalInCents Int
  order         SiteOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([orderId])
}

model OutOfStockWish {
  id        String   @id @default(cuid())
  productId String   @unique
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([attempts])
}

model StoreSettings {
  id               String   @id
  storeName        String
  heroTitle        String
  heroDescription  String
  heroPrimaryButtonLabel String @default("Ver Catálogo")
  heroSecondaryButtonLabel String @default("Sobre Nós")
  heroBenefitOne   String   @default("Perfumes 100% Originais")
  heroBenefitTwo   String   @default("Entrega rápida na Ilha Terceira")
  heroBenefitThree String   @default("Atendimento personalizado por WhatsApp")
  heroBenefitFour  String   @default("Amostras disponíveis em 5ml")
  heroImageUrl     String?
  heroMaleImageUrl String?
  heroFemaleImageUrl String?
  heroUnisexImageUrl String?
  decantsImageUrl  String?
  heroSlides       HeroSlide[]
  homeFeaturedEyebrow String @default("Mais vendidos")
  homeFeaturedTitle String @default("Os Preferidos dos Nossos Clientes")
  homeFeaturedDescription String @default("As fragrâncias mais procuradas e recomendadas pelos nossos clientes.")
  homeFeaturedButtonLabel String @default("Ver todos")
  homeDecantsEyebrow String @default("Serviço complementar")
  homeDecantsTitle String @default("Experimente antes de comprar")
  homeDecantsDescription String @default("Decants de 5ml e 10ml disponíveis em perfumes selecionados.")
  homeDecantsButtonLabel String @default("Ver Decants")
  homeWhyChooseEyebrow String @default("Confiança")
  homeWhyChooseTitle String @default("Porque Comprar na Perfumaria 9 Ilhas?")
  whyChooseItemOneTitle String @default("Entrega rápida na Ilha Terceira")
  whyChooseItemOneText String @default("Receba com rapidez e acompanhamento próximo.")
  whyChooseItemTwoTitle String @default("Envio para Açores, Madeira e Portugal Continental")
  whyChooseItemTwoText String @default("Preparamos cada encomenda com atenção e segurança.")
  whyChooseItemThreeTitle String @default("Perfumes 100% Originais")
  whyChooseItemThreeText String @default("Selecionamos referências autênticas e confiáveis.")
  whyChooseItemFourTitle String @default("Atendimento via WhatsApp")
  whyChooseItemFourText String @default("Respondemos de forma próxima e personalizada.")
  whyChooseItemFiveTitle String @default("Pagamento Seguro")
  whyChooseItemFiveText String @default("Confirmação clara antes de finalizar a encomenda.")
  homeTestimonialsEyebrow String @default("Testemunhos")
  homeTestimonialsTitle String @default("O que dizem os nossos clientes")
  catalogTitle     String
  catalogIntro     String
  contactTitle     String
  contactIntro     String
  footerDescription String
  location         String
  phone            String
  whatsappNumber   String
  whatsappLabel    String
  openingHours     String
  contactEmail     String?
  instagramUrl     String?
  facebookUrl      String?
  tiktokUrl        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model HeroSlide {
  id              String        @id @default(cuid())
  imageUrl        String
  position        Int
  durationSeconds Int           @default(4)
  storeSettingsId String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  storeSettings   StoreSettings @relation(fields: [storeSettingsId], references: [id], onDelete: Cascade)

  @@unique([storeSettingsId, position])
  @@index([storeSettingsId, position])
}

model StoreReview {
  id        String   @id @default(cuid())
  name      String
  rating    Int
  comment   String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved, createdAt])
}

model StoreMetric {
  id                      String   @id
  totalSatisfiedCustomers Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model DailySiteVisit {
  id         String   @id @default(cuid())
  dateKey    String   @unique
  visitCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([dateKey])
}

model StoredImage {
  id          String   @id @default(cuid())
  fileName    String   @unique
  contentType String
  data        Bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
